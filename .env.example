# Environment variables for Erin's Escapades
# Copy this file to .env.local and fill in values when switching to real Supabase

# Public Site URL (used for share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# Supabase Project URL and Anon Key (required for Vercel deploy)
# Find these in Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Optional, server-only) Service Role Key for server actions (never expose to client)
# SUPABASE_SERVICE_ROLE=

# Feature flags
# Set to 'true' to show the Google sign-in button
NEXT_PUBLIC_ENABLE_GOOGLE=false

# Demo login (optional): when true, entering email=trap and password=trap logs in a demo user
# On Supabase Auth, disable email confirmations for signup or pre-create this user
ENABLE_TRAP_LOGIN=false
