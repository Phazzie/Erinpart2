# Environment variables for Erin's Escapades
# Copy this file to .env.local and fill in values when switching to real Supabase

# Public Site URL (used for share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project URL and Anon Key
# You can find these in your Supabase project settings:
# Project Settings -> API -> Project URL and Public Key (anon)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
