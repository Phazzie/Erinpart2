# Environment variables for Erin's Escapades
# Copy this file to .env.local and fill in your actual values
# See docs/CLERK_SETUP.md for detailed setup instructions

# Public Site URL (used for share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
# Get your keys from: https://dashboard.clerk.com/last-active?path=api-keys
# IMPORTANT: Never commit real API keys! Use .env.local for actual values.

# Clerk Publishable Key (safe to expose to client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Clerk Secret Key (server-side only, NEVER expose to client)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# =============================================================================
# SUPABASE DATABASE
# =============================================================================
# We use Supabase for database only (Clerk handles authentication)
# Find these in Supabase: Project Settings > API

# Supabase Project URL (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (required for database access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (optional, server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
