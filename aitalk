        - Pin Node version to 22.x to match dev container.
      constraints:
        - Do not introduce new workflows; edit existing only.

    - id: tests-tasklist-interactions
      title: Add interaction tests for TaskList component
      scope:
        - components/tasks/task-list.test.tsx
      steps:
        - Mock useTasks to simulate add/update/delete flows and error states.
        - Test keyboard navigation (Enter to add, checkbox toggle) and empty state rendering.
