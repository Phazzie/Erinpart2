parallel_work:
  created_at: 2025-08-15T13:00:00Z
  owner: copilot
  summary: Define safe, non-overlapping tasks for gemini to run in parallel with Copilot's current session work.
  copilot_scope:
    files:
      - components/session/session-header.tsx
      - components/session/session-board.tsx
      - components/ui/textarea.tsx
      - lib/supabase/**
      - lib/actions.ts
      - hooks/use-tasks.ts
      - hooks/use-session.ts
      - hooks/use-realtime.ts
  gemini_allowed_scope:
    paths:
      - README.md
      - GEMINI.md
      - .github/workflows/**
      - docs/**
      - components/auth/** (tests only)
      - components/tasks/** (tests only)
      - hooks/use-tasks.test.ts
  gemini_restricted_scope:
    paths:
      - components/session/**
      - components/ui/button.tsx
      - lib/toast.tsx
      - hooks/use-realtime.ts (no edits)
      - hooks/use-session.ts (no edits)
      - lib/supabase/** (no edits)
      - lib/actions.ts (no edits)
      - jest.config.ts
      - next.config.mjs
      - tsconfig.json
  tasks:
    - id: docs-supabase-schema
      title: Author SQL schema and RLS policies for sessions, tasks (MVP)
      scope:
        - docs/supabase-schema.sql (new)
        - docs/supabase-policies.md (new)
      steps:
        - Define tables: sessions, tasks; columns per `lib/types.ts`.
        - Add basic indexes (session_id, order_index).
        - Draft RLS: owner read/write; participants read; public optional.
      constraints:
        - Docs only; no code changes.
    - id: docs-env-setup
      title: Document env setup and OAuth redirects
      scope:
        - README.md
        - .env.example (only comment additions)
      steps:
        - Explain NEXT_PUBLIC_SUPABASE_URL / ANON_KEY.
        - Add Google OAuth redirect URIs section (optional for MVP).
      constraints:
        - No breaking changes to env keys; keep names unchanged.
    - id: ci-tests
      title: Ensure CI runs jest tests and typecheck
      scope:
        - .github/workflows/quality-checks.yml
      steps:
        - Add/verify steps for npm test, npm run typecheck.
        - Use caching if helpful.
      constraints:
        - No secrets; do not add external services.
    - id: tests-use-session
      title: Add unit tests for use-session (mock Supabase)
      scope:
        - tests/hooks/use-session.test.ts (new)
      steps:
        - Mock `@/lib/supabase/client` to simulate getUser + onAuthStateChange.
        - Assert initial load, auth change updates, and cleanup.
      constraints:
        - Tests only; no changes to hook code.
    - id: docs-share-reply-polish
      title: Polish share/reply docs with examples and caveats
      scope:
        - docs/share-reply.md
      steps:
        - Add example URLs; clarify behavior with/without DB.
      constraints:
        - Docs only.

    - id: docs-architecture-overview
      title: Author Architecture Overview with diagrams (Mermaid)
      scope:
        - docs/architecture.md (new)
      steps:
        - Describe client (Next.js/React), server actions, Supabase (auth, DB, realtime), and mock fallback.
        - Include Mermaid sequence diagram for task CRUD + realtime.
        - Include component-level diagram for SessionBoard/TaskList interactions.
      constraints:
        - Docs only; no code changes.

    - id: docs-developer-setup
      title: Expand Developer Setup and Scripts
      scope:
        - README.md
        - docs/developer-setup.md (new)
      steps:
        - Add prerequisites (Node 22, npm), install, useful scripts (dev, build, typecheck, test, lint).
        - Add "Running tests locally" and troubleshooting notes for Jest + jsdom.
      constraints:
